# ─────────────────────────────────────────────────────────────────────────────
# DGX Monitor — environment configuration template
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── JWT / Authentication ──────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
# Leave empty → a random key is generated at startup (tokens invalidated on restart).
SECRET_KEY=

# Token lifetime in hours (default: 8)
JWT_EXPIRE_HOURS=8

# ── Runtime data directory ────────────────────────────────────────────────────
# Where services.json and per-user layouts are stored.
# Must be writable by the service user. Defaults to ./backend_data
# DATA_DIR=/var/lib/dgx-monitor

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=3001
