[Unit]
Description=DGX Monitoring (FastAPI + Uvicorn)
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/home/accadmin/workspace/monitoring
Environment="PATH=/home/accadmin/workspace/monitoring/.venv/bin"
ExecStart=/home/accadmin/workspace/monitoring/.venv/bin/uvicorn backend.app.main:app --host 0.0.0.0 --port 3001
Restart=on-failure

[Install]
WantedBy=multi-user.target
